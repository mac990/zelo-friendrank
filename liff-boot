(function () {
  'use strict';

  var LIFF_SDK_URL = 'https://static.line-scdn.net/liff/edge/2/sdk.js';

  function byId(id) {
    return document.getElementById(id);
  }

  function log() {
    try {
      console.log.apply(console, arguments);
    } catch (err) {}
  }

  function warn() {
    try {
      console.warn.apply(console, arguments);
    } catch (err) {}
  }

  function setStatus(text) {
    var el = byId('zg-liff-status');

    if (el) {
      el.textContent = text;
    }
  }

  function isShopifyEditor() {
    var href = String(window.location.href || '');
    var search = String(window.location.search || '');

    if (window.Shopify && window.Shopify.designMode) return true;
    if (href.indexOf('/admin/') !== -1) return true;
    if (href.indexOf('myshopify.com/admin') !== -1) return true;
    if (search.indexOf('preview_theme_id=') !== -1) return true;
    if (search.indexOf('_ab=') !== -1) return true;
    if (search.indexOf('_fd=') !== -1) return true;
    if (search.indexOf('pb=') !== -1) return true;

    try {
      if (window.self !== window.top) return true;
    } catch (err) {
      return true;
    }

    return false;
  }

  function getRoot() {
    return byId('zelo-liff-game');
  }

  function getLiffId() {
    var root = getRoot();

    if (root) {
      var fromDom = root.getAttribute('data-liff-id');

      if (fromDom) {
        return fromDom;
      }
    }

    if (window.ZELO_LIFF_ID) {
      return window.ZELO_LIFF_ID;
    }

    return '';
  }

  function getGoogleApi() {
    var root = getRoot();

    if (root) {
      var fromDom = root.getAttribute('data-google-record-api');

      if (fromDom) {
        return fromDom;
      }
    }

    if (window.ZELO_GOOGLE_RECORD_API) {
      return window.ZELO_GOOGLE_RECORD_API;
    }

    return '';
  }

  function getCurrentProfile() {
    if (window.ZELO_PROFILE) {
      return window.ZELO_PROFILE;
    }

    try {
      var saved = localStorage.getItem('zg_profile');

      if (saved) {
        return JSON.parse(saved);
      }
    } catch (err) {}

    return null;
  }

  function getUrlParam(name) {
    try {
      var url = new URL(window.location.href);
      return url.searchParams.get(name) || '';
    } catch (err) {
      return '';
    }
  }

  function getInviteParams() {
    return {
      inviterId:
        getUrlParam('inviterId') ||
        getUrlParam('ref') ||
        getUrlParam('referrerId') ||
        getUrlParam('fromUserId') ||
        '',
      inviterName:
        getUrlParam('inviterName') ||
        getUrlParam('refName') ||
        getUrlParam('referrerName') ||
        ''
    };
  }

  function buildRedirectUriPreserveParams() {
    try {
      var url = new URL(window.location.href);

      [
        'liff.state',
        'access_token',
        'id_token',
        'client_id',
        'scope',
        'state',
        'code',
        'friendship_status_changed',
        'error',
        'error_description'
      ].forEach(function (key) {
        url.searchParams.delete(key);
      });

      return url.toString();
    } catch (err) {
      return window.location.href;
    }
  }

  function normalizeEventType(eventType) {
    var t = String(eventType || '').toLowerCase().trim();

    if (!t) return '';

    if (t === 'copy-coupon') return 'coupon_copy';
    if (t === 'copycoupon') return 'coupon_copy';
    if (t === 'couponcopy') return 'coupon_copy';
    if (t === 'copy_coupon') return 'coupon_copy';
    if (t === 'download-coupon') return 'coupon_copy';

    if (t === 'officialsite') return 'official_click';
    if (t === 'gowebsite') return 'official_click';
    if (t === 'website') return 'official_click';
    if (t === 'shop_click') return 'official_click';

    if (t === 'share_click') return 'share';

    if (t === 'playagain') return 'play_again';
    if (t === 'replay_click') return 'play_again';

    if (t === 'couponused') return 'coupon_redeem';
    if (t === 'redeem') return 'coupon_redeem';

    return t;
  }

  function enrichPayload(payload) {
    payload = payload || {};

    var profile = getCurrentProfile() || {};
    var inviteParams = getInviteParams();

    var merged = {};

    Object.keys(payload).forEach(function (key) {
      merged[key] = payload[key];
    });

    if (merged.eventType) {
      merged.eventType = normalizeEventType(merged.eventType);
    }

    if (!merged.userId && profile.userId) merged.userId = profile.userId;
    if (!merged.userId && profile.id) merged.userId = profile.id;

    if (!merged.displayName && profile.displayName) merged.displayName = profile.displayName;
    if (!merged.displayName && profile.name) merged.displayName = profile.name;

    if (!merged.playerName && profile.name) merged.playerName = profile.name;
    if (!merged.playerName && profile.displayName) merged.playerName = profile.displayName;

    if (!merged.pictureUrl && profile.pictureUrl) merged.pictureUrl = profile.pictureUrl;

    if (!merged.inviterId && inviteParams.inviterId) merged.inviterId = inviteParams.inviterId;
    if (!merged.inviterName && inviteParams.inviterName) merged.inviterName = inviteParams.inviterName;

    if (!merged.pageUrl) merged.pageUrl = window.location.href;
    if (!merged.userAgent) merged.userAgent = navigator.userAgent || '';

    if (!merged.timestamp && !merged.playedAt) {
      merged.timestamp = new Date().toISOString();
    }

    return merged;
  }

  function setupGoogleSync() {
    var api = getGoogleApi();

    window.ZELO_GOOGLE_RECORD_API = api || '';

    window.ZELO_SYNC_SCORE_TO_GOOGLE = async function (payload) {
      if (!window.ZELO_GOOGLE_RECORD_API) {
        warn('[ZELO] Missing Google record API URL');
        return {
          ok: false,
          skipped: true,
          reason: 'missing-google-record-api'
        };
      }

      var enrichedPayload = enrichPayload(payload || {});

      try {
        await fetch(window.ZELO_GOOGLE_RECORD_API, {
          method: 'POST',
          mode: 'no-cors',
          headers: {
            'Content-Type': 'text/plain;charset=utf-8'
          },
          body: JSON.stringify(enrichedPayload)
        });

        log('[ZELO] Google record sync sent', enrichedPayload);

        return {
          ok: true,
          sent: true,
          payload: enrichedPayload
        };
      } catch (err) {
        warn('[ZELO] Google record sync failed:', err);

        return {
          ok: false,
          error: err && err.message ? err.message : String(err),
          payload: enrichedPayload
        };
      }
    };

    window.ZELO_TRACK_EVENT = function (eventType, payload) {
      payload = payload || {};
      payload.eventType = normalizeEventType(eventType || payload.eventType || '');

      return window.ZELO_SYNC_SCORE_TO_GOOGLE(payload);
    };

    window.ZELO_ENRICH_PAYLOAD = enrichPayload;
  }

  function loadScript(src) {
    return new Promise(function (resolve, reject) {
      var exists = document.querySelector('script[src="' + src + '"]');

      if (exists) {
        resolve();
        return;
      }

      var script = document.createElement('script');

      script.src = src;
      script.async = true;

      script.onload = function () {
        resolve();
      };

      script.onerror = function () {
        reject(new Error('Failed to load script: ' + src));
      };

      document.head.appendChild(script);
    });
  }

  function saveProfile(profile) {
    if (!profile) return;

    var normalized = {
      userId: profile.userId || '',
      displayName: profile.displayName || '你',
      pictureUrl: profile.pictureUrl || '',
      statusMessage: profile.statusMessage || ''
    };

    var gameProfile = {
      id: normalized.userId || 'me-local',
      userId: normalized.userId || 'me-local',
      name: normalized.displayName || '你',
      displayName: normalized.displayName || '你',
      pictureUrl: normalized.pictureUrl || '',
      statusMessage: normalized.statusMessage || '',
      isMe: true
    };

    window.ZELO_LIFF_PROFILE = normalized;
    window.ZELO_PROFILE = gameProfile;

    try {
      localStorage.setItem('zg_profile', JSON.stringify(gameProfile));
      localStorage.setItem('zelo_liff_profile', JSON.stringify(normalized));
    } catch (err) {}

    if (window.ZELO_GAME && typeof window.ZELO_GAME.setProfile === 'function') {
      try {
        window.ZELO_GAME.setProfile(normalized);
      } catch (err) {
        warn('[ZELO LIFF] ZELO_GAME.setProfile failed:', err);
      }
    }

    try {
      window.dispatchEvent(new CustomEvent('zelo:liff-profile-ready', {
        detail: {
          profile: normalized,
          gameProfile: gameProfile
        }
      }));
    } catch (err) {}
  }

  function fallback(reason) {
    window.ZELO_LIFF_BOOT_STATUS = 'fallback';

    if (reason) {
      warn('[ZELO LIFF] fallback:', reason);
    }

    setStatus('選擇你的陀螺，體驗真實物理碰撞與打擊感對戰。');
  }

  async function boot() {
    setupGoogleSync();

    if (isShopifyEditor()) {
      window.ZELO_LIFF_BOOT_STATUS = 'editor-skip';
      setStatus('編輯器預覽模式：LINE 登入只會在正式前台啟用。');
      log('[ZELO LIFF] skipped in Shopify editor');
      return;
    }

    var root = getRoot();

    if (!root) {
      fallback('Missing #zelo-liff-game');
      return;
    }

    var liffId = getLiffId();

    if (!liffId) {
      fallback('Missing LIFF ID');
      return;
    }

    try {
      setStatus('正在連接 LINE...');

      await loadScript(LIFF_SDK_URL);

      if (!window.liff) {
        fallback('LIFF SDK loaded but window.liff missing');
        return;
      }

      await window.liff.init({
        liffId: liffId
      });

      window.ZELO_LIFF_BOOT_STATUS = 'initialized';

      if (!window.liff.isLoggedIn()) {
        setStatus('請登入 LINE 後開始遊戲。');

        window.liff.login({
          redirectUri: buildRedirectUriPreserveParams()
        });

        return;
      }

      setStatus('正在讀取 LINE 個人資料...');

      var profile = await window.liff.getProfile();

      saveProfile(profile);

      window.ZELO_LIFF_BOOT_STATUS = 'profile-ready';

      setStatus('歡迎 ' + (profile.displayName || '你') + '，開始挑戰吧！');
    } catch (err) {
      fallback(err && err.message ? err.message : err);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
